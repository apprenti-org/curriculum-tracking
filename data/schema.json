{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rti.academy/schemas/curriculum.json",
  "description": "Schema for RTI Academy curriculum tracking data (courses.json)",

  "type": "object",
  "required": ["courses", "curricula"],

  "properties": {
    "courses": {
      "type": "array",
      "items": { "$ref": "#/definitions/course" }
    },
    "curricula": {
      "type": "array",
      "items": { "$ref": "#/definitions/curriculum" }
    }
  },

  "definitions": {
    "course": {
      "type": "object",
      "required": ["id", "name", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Stable course identifier (kebab-case). Never changes once set."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name. Can be updated without breaking references."
        },
        "hours": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total course hours. Null if not yet determined."
        },
        "status": {
          "type": "object",
          "required": ["design", "development"],
          "properties": {
            "design": { "$ref": "#/definitions/statusValue" },
            "development": { "$ref": "#/definitions/statusValue" }
          }
        },
        "syllabus": {
          "type": ["string", "null"],
          "description": "Syllabus reference — Google Doc title, URL, or null"
        },
        "outline": {
          "type": ["string", "boolean", "null"],
          "description": "Outline reference — title string, boolean, or null"
        },
        "note": {
          "type": ["string", "null"],
          "description": "Free-text note about course content or status"
        },
        "driveFolder": {
          "type": ["string", "null"],
          "description": "Google Drive folder URL for source materials"
        }
      }
    },

    "statusValue": {
      "type": "string",
      "enum": ["Not Started", "Scoping", "In Progress", "Needs Review", "In Review", "Complete"]
    },

    "curriculum": {
      "type": "object",
      "required": ["name"],
      "description": "A curriculum has either 'groups' (with nested courses) or a flat 'courses' array",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Kebab-case identifier. Matches curricula/[slug]/ folder."
        },
        "standard": {
          "type": "object",
          "description": "Governing DOL standard (Appendix) for this curriculum",
          "properties": {
            "appendix": {
              "type": "string",
              "description": "Appendix number (e.g. A-28)"
            },
            "title": {
              "type": "string",
              "description": "Official occupation title from the standard"
            },
            "onetSocCode": {
              "type": "string",
              "description": "O*NET-SOC occupation code"
            },
            "rapidsCode": {
              "type": "string",
              "description": "RAPIDS apprenticeship code"
            },
            "sourceUrl": {
              "type": "string",
              "format": "uri",
              "description": "URL to the authoritative source PDF"
            },
            "markdownReference": {
              "type": "string",
              "description": "Path to extracted markdown in _STANDARDS/"
            }
          }
        },
        "syllabus": {
          "type": ["string", "null"],
          "description": "Curriculum-level syllabus URL"
        },
        "groups": {
          "type": "array",
          "items": { "$ref": "#/definitions/group" }
        },
        "courses": {
          "type": "array",
          "items": { "$ref": "#/definitions/courseRef" }
        }
      }
    },

    "group": {
      "type": "object",
      "required": ["name", "courses"],
      "properties": {
        "name": { "type": "string" },
        "hours": { "type": ["integer", "null"] },
        "note": { "type": ["string", "null"] },
        "courses": {
          "type": "array",
          "items": { "$ref": "#/definitions/courseRef" }
        }
      }
    },

    "courseRef": {
      "description": "Reference to a course within a curriculum. Three formats: (1) plain ID string for simple refs, (2) object with 'id' + optional overrides, (3) legacy object with 'name' only (deprecated, for unresolved refs).",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Simple ref — course ID string (most common)"
        },
        {
          "type": "object",
          "required": ["id"],
          "description": "Override ref — course ID with per-curriculum overrides",
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$",
              "description": "Stable course ID"
            },
            "hoursOverride": {
              "type": ["integer", "null"],
              "description": "Per-curriculum hour override"
            },
            "note": {
              "type": ["string", "null"],
              "description": "Per-curriculum note"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["name"],
          "description": "Legacy ref — name-only, no matching course ID (deprecated). Will generate build warnings.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Course display name (unresolved — no matching course in system)"
            },
            "hoursOverride": {
              "type": ["integer", "null"],
              "description": "Per-curriculum hour override"
            },
            "note": {
              "type": ["string", "null"],
              "description": "Per-curriculum note"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
